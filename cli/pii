#!/usr/bin/env python3
"""
pii — manage PII mask app classification.

Usage:
    pii allow <name>       Add app to safe list (by process name or bundle ID)
    pii deny <name>        Remove app from safe list
    pii list               Show current allow/deny lists
    pii show               Show on-screen windows with classification
    pii diag               Diagnose daemon + shared memory health
"""

import sys
import os

# Add lib dir for shared imports — resolve symlinks first
_script_dir = os.path.dirname(os.path.realpath(__file__))
sys.path.insert(0, os.path.join(_script_dir, "..", "lib"))

from config_loader import load_config, save_config, CONFIG_PATH


def cmd_allow(name: str) -> None:
    cfg = load_config()
    allow = cfg["allow"]
    always_mask = cfg["always_mask"]

    # Remove from always_mask if present
    always_mask.discard(name)
    allow.add(name)

    save_config(sorted(allow), sorted(always_mask))
    print(f"✓ {name} → allowed")


def cmd_deny(name: str) -> None:
    cfg = load_config()
    allow = cfg["allow"]
    always_mask = cfg["always_mask"]

    allow.discard(name)
    # Add to always_mask so it's explicitly denied even if re-added later
    always_mask.add(name)

    save_config(sorted(allow), sorted(always_mask))
    print(f"✓ {name} → denied (always masked)")


def cmd_list() -> None:
    cfg = load_config()
    print(f"Config: {CONFIG_PATH}\n")

    print("ALLOWED (shown on stream):")
    for name in sorted(cfg["allow"]):
        print(f"  + {name}")

    print("\nALWAYS MASKED:")
    for name in sorted(cfg["always_mask"]):
        print(f"  - {name}")

    print(f"\nEverything else: masked (default-deny)")


def cmd_show() -> None:
    """Show on-screen windows with their classification."""
    try:
        from Quartz import (
            CGWindowListCopyWindowInfo,
            kCGWindowListOptionOnScreenOnly,
            kCGNullWindowID,
            kCGWindowBounds,
            kCGWindowLayer,
            kCGWindowOwnerName,
            kCGWindowOwnerPID,
            kCGWindowName,
        )
    except ImportError:
        print("Error: PyObjC (Quartz) required for 'pii show'")
        sys.exit(1)

    from classifier import Classifier

    cfg = load_config()
    classifier = Classifier(allow=cfg["allow"], always_mask=cfg["always_mask"])

    window_list = CGWindowListCopyWindowInfo(
        kCGWindowListOptionOnScreenOnly, kCGNullWindowID
    )

    if not window_list:
        print("No windows found")
        return

    # Collect unique apps with their classification
    # Only classify normal-layer (0) windows — same as the daemon
    apps = {}
    for w in window_list:
        owner = w.get(kCGWindowOwnerName, "")
        if not owner:
            continue
        layer = w.get(kCGWindowLayer, 0)
        title = w.get(kCGWindowName, "") or ""

        unsafe = classifier.is_unsafe(owner=owner, title=title, layer=layer)

        if owner not in apps:
            apps[owner] = {"unsafe": unsafe, "windows": 0, "normal": layer == 0}
        apps[owner]["windows"] += 1
        if layer == 0:
            apps[owner]["normal"] = True

    print(f"{'STATUS':<8} {'APP':<30} {'WINDOWS':>7}  NOTE")
    print("-" * 58)
    for owner in sorted(apps):
        info = apps[owner]
        if not info["normal"]:
            # System-level window, not processed by daemon
            marker = "·"
            status = "SYS"
            note = "(non-zero layer, ignored)"
        elif info["unsafe"]:
            marker = "●"
            status = "MASK"
            note = ""
        else:
            marker = "○"
            status = "SHOW"
            note = ""
        print(f"{marker} {status:<5}  {owner:<30} {info['windows']:>5}  {note}")


def cmd_diag() -> None:
    """Diagnose daemon + shared memory health."""
    import ctypes
    import ctypes.util
    import mmap
    import struct
    import time

    libc = ctypes.CDLL(ctypes.util.find_library("c"), use_errno=True)
    libc.shm_open.restype = ctypes.c_int
    libc.shm_open.argtypes = [ctypes.c_char_p, ctypes.c_int, ctypes.c_uint16]

    fd = libc.shm_open(b"/pii_mask", os.O_RDONLY, 0o666)
    if fd < 0:
        errno = ctypes.get_errno()
        print("SHM:      /pii_mask NOT FOUND")
        print(f"          errno={errno} — daemon likely not running")
        print()
        _diag_process()
        return

    buf = mmap.mmap(fd, 800, mmap.MAP_SHARED, mmap.PROT_READ)
    magic, version, seq, rect_count = struct.unpack_from("<IIII", buf, 0)
    ts_ns, = struct.unpack_from("<Q", buf, 16)
    flags, = struct.unpack_from("<I", buf, 24)
    screen_w, screen_h = struct.unpack_from("<HH", buf, 28)
    os.close(fd)

    now_ns = time.time_ns()
    age_ms = (now_ns - ts_ns) / 1_000_000
    stale = age_ms > 5000

    alive = bool(flags & 0x1)
    full_mask = bool(flags & 0x2)

    ok = "✓" if magic == 0x50494D53 else "✗"
    print(f"SHM:      /pii_mask found")
    print(f"Magic:    {ok} 0x{magic:08X} {'(valid)' if magic == 0x50494D53 else '(INVALID — expect 0x50494D53)'}")
    print(f"Version:  {version}")
    print(f"Sequence: {seq}")
    print(f"Screen:   {screen_w}x{screen_h}")
    print()

    ok = "✓" if alive else "✗"
    print(f"Daemon:   {ok} {'alive' if alive else 'NOT alive'}")
    print(f"Age:      {age_ms:.0f}ms {'(STALE — >5s)' if stale else '(fresh)'}")

    fm = "✗ ON — entire screen masked!" if full_mask else "✓ off"
    print(f"FullMask: {fm}")
    print(f"Rects:    {rect_count}")

    if rect_count > 0:
        print()
        for i in range(min(rect_count, 32)):
            off = 32 + i * 24
            x, y, w, h, cr, rf = struct.unpack_from("<fffffi", buf, off)
            unsafe = bool(rf & 1)
            print(f"  [{i:2d}] {x:.0f},{y:.0f} {w:.0f}x{h:.0f}  {'UNSAFE' if unsafe else 'safe'}")

    print()
    _diag_process()


def _diag_process() -> None:
    """Check if the daemon process is running."""
    import subprocess
    result = subprocess.run(
        ["pgrep", "-fl", "PiiMaskDaemon"],
        capture_output=True, text=True,
    )
    if result.stdout.strip():
        print(f"Process:  ✓ running")
        for line in result.stdout.strip().splitlines():
            print(f"          {line}")
    else:
        print("Process:  ✗ PiiMaskDaemon not found")


def usage():
    print(__doc__.strip())
    sys.exit(1)


def main():
    if len(sys.argv) < 2:
        usage()

    cmd = sys.argv[1]

    if cmd == "allow" and len(sys.argv) >= 3:
        cmd_allow(" ".join(sys.argv[2:]))
    elif cmd == "deny" and len(sys.argv) >= 3:
        cmd_deny(" ".join(sys.argv[2:]))
    elif cmd == "list":
        cmd_list()
    elif cmd == "show":
        cmd_show()
    elif cmd == "diag":
        cmd_diag()
    else:
        usage()


if __name__ == "__main__":
    main()
